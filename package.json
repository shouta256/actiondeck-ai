{
  "name": "actiondeck-ai",
  "version": "0.1.0",
  "private": true,
  "description": "根拠付きAction Cardを生成・レビューするPersonal Action Review Agent",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "cd apps/api && uv run fastapi dev main.py",
    "start:db": "docker compose -f infra/docker-compose.yml up -d",
    "stop:db": "docker compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
