# git管理しないファイルの設定

# 依存関係
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# テスト
/coverage

# Next.js
/.next/
/out/

# 本番ビルド
/build

